.ruff_cache/

# Node
node_modules/
.pnpm-store/
dist/
build/
coverage/

# IDE / OS
.DS_Store
.idea/
.vscode/

# Imports artifact (one-shot)
.import-work/

# Traefik ACME storage (if ever mounted to host)
traefik_acme/
