MODEL_KEY=dense
MODEL_DISPLAY_NAME=unsloth/Qwen3.5-2B-GGUF
MODEL_ROLE=dense
MODEL_SOURCE_REPO=Qwen/Qwen3.5-2B
MODEL_REPO=unsloth/Qwen3.5-2B-GGUF
MODEL_FILENAME=Qwen3.5-2B-Q8_0.gguf
MODEL_INCLUDE_PATTERN=Qwen3.5-2B-Q8_0.gguf
MODEL_REVISION=main
MODEL_DIR=${PROJECT_ROOT}/models/dense
MODEL_FILE=${MODEL_DIR}/${MODEL_FILENAME}
MODEL_ALLOWED_DEVICES=cpu,gpu
MODEL_DEVICE=gpu
MODEL_HOST=0.0.0.0
MODEL_PORT=8102
SERVER_MODE=generate
# Qwen3.5-2B Q8_0 ≈ 1.9 GB VRAM for weights.
# 60416 context with Q8_0 KV cache uses ~1.1 GB for KV,
# bringing dense to ~2.85 GB. Combined with embeddings (~1.1 GB)
# total usage is ~4007 MiB / 4096 MiB on the Quadro P1000.
CONTEXT_SIZE=60416
THREADS=12
PARALLEL=1
CPU_BATCH=512
CPU_UBATCH=128
GPU_BATCH=1024
GPU_UBATCH=512
GPU_LAYERS=99
CPU_EXTRA_ARGS=
GPU_EXTRA_ARGS="--cache-type-k q8_0 --cache-type-v q8_0"
SERVER_EXTRA_ARGS=--no-webui
LORA_ENABLED=false
