MODEL_KEY=embeddings
MODEL_DISPLAY_NAME=nomic-embed-text-v2-moe
MODEL_ROLE=embedding
MODEL_SOURCE_REPO=nomic-ai/nomic-embed-text-v2-moe
MODEL_REPO=nomic-ai/nomic-embed-text-v2-moe-GGUF
MODEL_FILENAME=nomic-embed-text-v2-moe.Q8_0.gguf
MODEL_INCLUDE_PATTERN=nomic-embed-text-v2-moe.Q8_0.gguf
MODEL_REVISION=main
MODEL_DIR=${PROJECT_ROOT}/models/embeddings
MODEL_FILE=${MODEL_DIR}/${MODEL_FILENAME}
MODEL_ALLOWED_DEVICES=cpu,gpu
MODEL_DEVICE=gpu
MODEL_HOST=0.0.0.0
MODEL_PORT=8101
SERVER_MODE=embedding
POOLING=mean
# nomic-embed-text-v2-moe supports 512 tokens and emits 768-dim vectors.
# Q8_0 weights ≈ 512 MiB, fitting comfortably in the 4 GB VRAM budget.
CONTEXT_SIZE=512
THREADS=12
PARALLEL=1
CPU_BATCH=2048
CPU_UBATCH=512
GPU_BATCH=1024
GPU_UBATCH=512
GPU_LAYERS=99
CPU_EXTRA_ARGS=
GPU_EXTRA_ARGS="--cache-type-k q4_0 --cache-type-v q4_0"
SERVER_EXTRA_ARGS=--no-webui
LORA_ENABLED=false
