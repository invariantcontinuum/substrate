MODEL_KEY=embeddings
MODEL_DISPLAY_NAME=jina-code-embeddings-0.5b
MODEL_ROLE=embedding
MODEL_SOURCE_REPO=jinaai/jina-code-embeddings-0.5b
MODEL_REPO=mradermacher/jina-code-embeddings-0.5b-GGUF
MODEL_FILENAME=jina-code-embeddings-0.5b.Q8_0.gguf
MODEL_INCLUDE_PATTERN=jina-code-embeddings-0.5b.Q8_0.gguf
MODEL_REVISION=main
MODEL_DIR=${PROJECT_ROOT}/models/embeddings
MODEL_FILE=${MODEL_DIR}/${MODEL_FILENAME}
MODEL_ALLOWED_DEVICES=cpu,gpu
MODEL_DEVICE=gpu
MODEL_HOST=0.0.0.0
MODEL_PORT=8101
SERVER_MODE=embedding
POOLING=last
# jina-code-embeddings-0.5b supports 32768 tokens and emits 896-dim vectors.
# Q8_0 weights ≈ 600 MiB, fitting comfortably in the 4 GB VRAM budget.
CONTEXT_SIZE=32768
THREADS=12
PARALLEL=1
CPU_BATCH=2048
CPU_UBATCH=512
GPU_BATCH=1024
GPU_UBATCH=512
GPU_LAYERS=99
CPU_EXTRA_ARGS=
GPU_EXTRA_ARGS="--cache-type-k q8_0 --cache-type-v q8_0"
SERVER_EXTRA_ARGS=--no-webui
LORA_ENABLED=false
