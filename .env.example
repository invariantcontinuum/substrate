# Graph Service — environment variables
#
# This file documents every env var the Graph Service reads. Copy to
# `.env` (NOT checked in) and fill with real values for local runs.

# Postgres (substrate_graph database)
DATABASE_URL=postgresql+asyncpg://substrate_graph:changeme@localhost:5432/substrate_graph

# Flyway (Dockerfile entrypoint runs migrations at container boot)
FLYWAY_URL=jdbc:postgresql://localhost:5432/substrate_graph
FLYWAY_USER=substrate_graph
FLYWAY_PASSWORD=changeme

# LLM endpoints — match the active lazy-lamacpp deployment.
# EMBEDDING_URL is used by the semantic-search route.
# DENSE_LLM_URL is used by the enriched-summary pipeline.
EMBEDDING_URL=http://localhost:8101/v1/embeddings
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v2-moe-GGUF
EMBEDDING_DIM=768
DENSE_LLM_URL=http://localhost:8102/v1/chat/completions
DENSE_LLM_MODEL=unsloth/Qwen3.5-4B-GGUF
LLM_API_KEY=test

# Summary output controls
SUMMARY_MAX_TOKENS=160
SUMMARY_CHUNK_SAMPLE_CHARS=4000

# Enriched summary knobs (Task A5)
SUMMARY_EDGE_NEIGHBORS=10
SUMMARY_TOTAL_BUDGET_CHARS=48000
SUMMARY_NEIGHBOR_CHARS=1200
SUMMARY_FILE_BUDGET_RATIO=0.70
SUMMARY_NEIGHBOR_BUDGET_RATIO=0.25

# HTTP port inside the container (compose maps 8182:8082)
APP_PORT=8082

# AGE query wall-clock cap (in seconds) for merged-graph reads
GRAPH_QUERY_TIMEOUT_SECONDS=60
