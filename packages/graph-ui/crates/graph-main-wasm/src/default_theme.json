{
  "background": "#0d0d12",
  "nodes": {
    "default": {
      "shape": "roundrectangle",
      "size": 30,
      "halfWidth": 55,
      "halfHeight": 19,
      "cornerRadius": 0.25,
      "color": "#0d0d12",
      "borderWidth": 1.5,
      "borderColor": "rgba(255,255,255,0.12)",
      "label": { "field": "name", "color": "#c0c0d8", "size": 11 }
    },
    "byType": {
      "service":  { "color": "#0f0f1f", "borderColor": "#3b4199" },
      "database": { "shape": "barrel", "color": "#0a1a14", "borderColor": "#065f46" },
      "cache":    { "shape": "barrel", "color": "#0a1a14", "borderColor": "#047857" },
      "policy":   { "shape": "diamond", "halfWidth": 55, "halfHeight": 24, "color": "#150a2a", "borderColor": "#7c3aed", "borderWidth": 2 },
      "adr":      { "halfWidth": 40, "halfHeight": 16, "color": "#1a1400", "borderColor": "#92400e" },
      "incident": { "halfWidth": 40, "halfHeight": 16, "color": "#1a0505", "borderColor": "#991b1b" },
      "external": { "halfWidth": 45, "halfHeight": 16, "color": "#0d1117", "borderColor": "#374151" }
    },
    "byStatus": {
      "violation": { "color": "#1a0505", "borderColor": "#ef4444", "borderWidth": 2, "pulse": true }
    }
  },
  "edges": {
    "default": { "color": "rgba(255,255,255,0.1)", "width": 1, "arrow": "target" },
    "byType": {
      "depends":    { "color": "rgba(99,102,241,0.3)" },
      "depends_on": { "color": "rgba(99,102,241,0.3)" },
      "violation":  { "color": "#ef4444", "width": 2, "style": "dashed", "animate": true },
      "enforces":   { "color": "rgba(168,85,247,0.5)", "width": 1.5, "style": "dotted" },
      "why":        { "color": "rgba(245,158,11,0.5)", "width": 1.5, "style": "dashed" },
      "drift":      { "color": "rgba(239,68,68,0.3)", "style": "dashed" }
    }
  },
  "communities": { "hull": false, "hullOpacity": 0.06, "palette": "categorical-12" },
  "interaction": {
    "hover": { "scale": 1.3, "highlightNeighbors": true, "dimOthers": 0.15 },
    "select": { "borderColor": "#ffffff", "borderWidth": 3, "expandLabel": true },
    "spotlight": { "dimOpacity": 0.05, "transitionMs": 300 }
  }
}
