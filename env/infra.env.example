# Postgres
POSTGRES_VERSION=16
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change-me

# Substrate graph DB credentials
GRAPH_DB_USER=substrate_graph
GRAPH_DB_PASSWORD=change-me
GRAPH_DB_NAME=substrate_graph

# Keycloak DB credentials
KC_DB_USER=keycloak
KC_DB_PASSWORD=change-me
KC_DB_NAME=keycloak

# Keycloak bootstrap admin (only consulted on first start)
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me

# Substrate-gateway confidential client secret — injected into the generated
# realm JSON and read by the gateway when exchanging service-account tokens.
# Rotate by editing this value and re-running `make configure`.
KC_GATEWAY_CLIENT_SECRET=change-me

# GitHub OAuth app (identity broker). Leave blank to disable the GitHub IdP.
GITHUB_OAUTH_APP_CLIENT_ID=
GITHUB_OAUTH_APP_CLIENT_SECRET=

# pgadmin (dev-only service; not deployed in prod)
PGADMIN_DEFAULT_EMAIL=admin@substrate.dev
PGADMIN_DEFAULT_PASSWORD=change-me
