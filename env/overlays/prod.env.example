# Prod overlay — materialized by scripts/set-env.sh prod --domain=<your-domain>.
# Only ROOT_DOMAIN and ACME_EMAIL need to be supplied; every other value
# is derived. Re-run `make configure MODE=prod DOMAIN=...` to regenerate.
DEPLOYMENT_MODE=prod
ROOT_DOMAIN=example.com
SCHEME=https

# Subdomains — change only if you want non-standard names.
APP_SUBDOMAIN=app
AUTH_SUBDOMAIN=auth

# TLS via bundled Traefik. Set to a contactable address for Let's Encrypt.
ACME_EMAIL=admin@example.com

# Derived browser URLs (regenerated from ROOT_DOMAIN + SCHEME + subdomains).
APP_URL=https://app.example.com
AUTH_URL=https://auth.example.com
KEYCLOAK_ISSUER=https://auth.example.com/realms/substrate
KC_HOSTNAME=https://auth.example.com
KC_HOSTNAME_STRICT=true
KC_HTTP_ENABLED=false
KC_START_COMMAND=start

# Vite build args
VITE_KEYCLOAK_URL=https://auth.example.com

# CORS: only the prod app origin is allowed.
CORS_ORIGINS=["https://app.example.com"]

# Never enable AUTH_DISABLED in prod.
AUTH_DISABLED=false
