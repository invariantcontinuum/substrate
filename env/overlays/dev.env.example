# Dev overlay — materialized by scripts/set-env.sh dev.
# All values are localhost-scoped. Do not edit the generated dev.env by hand;
# re-run `make configure MODE=dev` to regenerate it.
DEPLOYMENT_MODE=dev
ROOT_DOMAIN=localhost
SCHEME=http

# Host-published ports for dev (browser reaches them directly).
FRONTEND_HOST_PORT=3535
KEYCLOAK_HOST_PORT=8080
GATEWAY_HOST_PORT=8180
INGESTION_HOST_PORT=8181
GRAPH_HOST_PORT=8182
POSTGRES_HOST_PORT=5432
PGADMIN_HOST_PORT=5050

# Browser-facing URLs derived from the above.
APP_URL=http://localhost:3535
AUTH_URL=http://localhost:8080
KEYCLOAK_ISSUER=http://localhost:8080/realms/substrate
KC_HOSTNAME=http://localhost:8080
KC_HOSTNAME_STRICT=false
KC_HTTP_ENABLED=true
KC_START_COMMAND=start-dev

# Vite build args
VITE_KEYCLOAK_URL=http://localhost:8080

# CORS: dev accepts the host-published frontend origin.
CORS_ORIGINS=["http://localhost:3535","http://localhost:3000"]

# Gateway can short-circuit JWT validation in dev only.
AUTH_DISABLED=false
