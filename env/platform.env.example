# Application services
SERVICE_LOG_PRETTY=0
GATEWAY_PORT=8080
INGESTION_PORT=8081
GRAPH_PORT=8082

# Keycloak (browser-facing issuer; matches KC_HOSTNAME inside the keycloak container)
KEYCLOAK_REALM=substrate
KEYCLOAK_ISSUER=http://localhost:8080/realms/substrate

# Keycloak internal URL (JWKS fetch only — container DNS)
KEYCLOAK_URL=http://keycloak:8080

# Gateway auth bypass (dev only; do not set in prod)
AUTH_DISABLED=false

# Gateway CORS
CORS_ORIGINS=["http://localhost:3535"]
