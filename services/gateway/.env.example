# Substrate Gateway environment variables.

# Keycloak
KEYCLOAK_URL=http://local-keycloak:8080
KEYCLOAK_REALM=substrate
KEYCLOAK_ISSUER=

# Upstream services
GRAPH_SERVICE_URL=http://substrate-graph:8082
INGESTION_SERVICE_URL=http://substrate-ingestion:8081
REDIS_URL=redis://local-redis:6379

# Dev-mode auth bypass. Default false. Set true to short-circuit JWT
# validation and emit stub admin claims. Only for local dev against
# brainrot or Keycloak-off scenarios.
AUTH_DISABLED=false

# CORS allowed origins, JSON list. Default allows brainrot dev only.
CORS_ORIGINS=["http://localhost:3535"]
