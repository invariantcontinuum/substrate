# Substrate Gateway — per-service env example.
# In practice all of these come from the monorepo-wide env/* bundle that
# `make configure MODE=dev|prod` materializes into .env. This file
# documents the vars the gateway itself reads.

# Keycloak (internal container DNS and browser-facing issuer)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=substrate
KEYCLOAK_ISSUER=

# substrate-gateway confidential client secret (shared with the realm JSON)
KC_GATEWAY_CLIENT_SECRET=

# Upstream services
GRAPH_SERVICE_URL=http://graph:8082
INGESTION_SERVICE_URL=http://ingestion:8081

# Dev-only: short-circuit JWT validation. Never enable in prod.
AUTH_DISABLED=false

# CORS allowed origins (JSON list).
CORS_ORIGINS=["http://localhost:3535"]
