# Frontend build-time configuration template.
#
# Vite reads `VITE_*` keys at build time and bakes them into the bundle.
# Anything not prefixed with `VITE_` is ignored by the build but kept here
# for documentation parity with the runtime API config (see
# `useEffectiveConfig` in src/hooks/useRuntimeConfig.ts).
#
# Layered precedence (highest first), matching the Python services:
#   1. runtime UI config — written to Postgres `runtime_config` via
#      `PUT /api/config/{section}`, broadcast over SSE, applied without
#      rebuild. The frontend reads this through `useEffectiveConfig`.
#   2. CLI / build flags — `vite build --mode prod`, `--define`.
#   3. Process env at build time (this file when copied to `.env`).
#   4. apps/frontend/.env (committed; should mirror this file's defaults).
#   5. Hardcoded fallbacks in `src/lib/auth.ts` (last resort).

# ── Keycloak (browser-facing OIDC issuer) ────────────────────────────
# The browser POSTs to `${VITE_KEYCLOAK_URL}/realms/${VITE_KEYCLOAK_REALM}/...`.
# In dev this is the localhost compose endpoint; in prod it's the public
# auth subdomain (set via .env.prod for `make up MODE=prod`).
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=substrate
VITE_KEYCLOAK_CLIENT_ID=substrate-frontend
