# Frontend build-time configuration — committed defaults.
#
# This file ships with the repo so a fresh checkout builds without
# manual setup. Override per-environment via `.env.local` (gitignored)
# or by setting `VITE_*` vars in the build environment.
#
# See .env.example for the full layered-config explanation.

VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=substrate
VITE_KEYCLOAK_CLIENT_ID=substrate-frontend
