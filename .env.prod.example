# ╔════════════════════════════════════════════════════════════════════╗
# ║ Substrate — PRODUCTION config                                     ║
# ║ Copy to `.env.prod`, fill <your-domain> + real secrets, then       ║
# ║ `make up MODE=prod`. home-stack's NPM terminates TLS upstream and ║
# ║ proxies app.<domain>:3535 and auth.<domain>:8080 via               ║
# ║ host.docker.internal — substrate publishes the same ports in both ║
# ║ modes, so only the URL block below differs.                        ║
# ╚════════════════════════════════════════════════════════════════════╝


# ────────────── Browser-facing URLs (mode-specific) ─────────────────
APP_URL=https://app.<your-domain>
VITE_KEYCLOAK_URL=https://auth.<your-domain>
KEYCLOAK_ISSUER=https://auth.<your-domain>/realms/substrate
KC_HOSTNAME=https://auth.<your-domain>
KC_HOSTNAME_STRICT=true
KC_START_COMMAND=start
KC_HTTP_ENABLED=true
CORS_ORIGINS=["https://app.<your-domain>"]


# ────────────── Shared ──────────────────────────────────────────────
KEYCLOAK_REALM=substrate
# Browser (public) Keycloak client id used by the frontend OIDC flow.
# Surfaced read-only in Settings → Authentication. Trade-off: changing
# this requires updating the matching client in the Keycloak realm
# (see scripts/render-realm.py); leave at the default unless you've
# renamed the client.
KEYCLOAK_PUBLIC_CLIENT_ID=substrate-frontend
# Optional explicit account-console URL. Leave empty to derive
# `<KEYCLOAK_ISSUER>/account/` automatically. Override only when the
# account console lives behind a different hostname than the issuer.
KEYCLOAK_ACCOUNT_CONSOLE_URL=
SERVICE_LOG_PRETTY=0
# Never set to `true` in prod — bypasses JWT validation entirely.
AUTH_DISABLED=false


# ────────────── Postgres (single DB: substrate_graph) ───────────────
POSTGRES_VERSION=16
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=<set-a-strong-password>
GRAPH_DB_USER=substrate_graph
GRAPH_DB_PASSWORD=<set-a-strong-password>
GRAPH_DB_NAME=substrate_graph


# ────────────── Keycloak ────────────────────────────────────────────
KC_DB_USER=keycloak
KC_DB_PASSWORD=<set-a-strong-password>
KC_DB_NAME=keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=<set-a-strong-password>
# Allow self-service account registration on the Keycloak login page.
# Keep true for multi-user SaaS onboarding; set false for invite/admin-only orgs.
KEYCLOAK_REGISTRATION_ALLOWED=true
# Rotate this value, then `make up && make nuke-keycloak` to re-import
# the realm with the new gateway client secret.
KC_GATEWAY_CLIENT_SECRET=<generate-random-secret>
GITHUB_OAUTH_APP_CLIENT_ID=
GITHUB_OAUTH_APP_CLIENT_SECRET=

# ────────────── Gateway: API tokens (PATs) ──────────────────────────
# Personal access tokens consumed by the bearer-auth fast-path in the
# gateway. Trade-off: shorter random body = easier brute force; longer
# = more clipboard awkward. 24 url-safe bytes ≈ 192 bits entropy.
API_TOKEN_PLAINTEXT_PREFIX=subs_
API_TOKEN_RANDOM_BYTES=24      # secrets.token_urlsafe(N) -> ~⌈4N/3⌉ chars
API_TOKEN_DISPLAY_PREFIX_LEN=8 # chars shown in the UI list to disambiguate


# ────────────── pgadmin ─────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@<your-domain>
PGADMIN_DEFAULT_PASSWORD=<set-a-strong-password>


# ════════════════════════════════════════════════════════════════════
# ║ AI / LLM configuration                                           ║
# ║ Defaults pair with lazy-lamacpp's currently-served models.       ║
# ║ Changing the LLM's CONTEXT_SIZE in                               ║
# ║ <llm-stack>/config/models/<name>.env requires updating  ║
# ║ SUMMARY_TOTAL_BUDGET_CHARS and/or EMBEDDING_MAX_INPUT_CHARS       ║
# ║ here so prompts stay inside the context window.                  ║
# ╚════════════════════════════════════════════════════════════════════

# ── Embedding LLM endpoint ──
EMBEDDING_URL=http://host.docker.internal:8101/v1/embeddings
EMBEDDING_MODEL=embeddings
EMBEDDING_DIM=768
EMBEDDING_DOCUMENT_PREFIX=search_document:
EMBEDDING_QUERY_PREFIX=search_query:
EMBEDDING_MAX_INPUT_CHARS=1400
EMBED_BATCH_SIZE=32
# Embedding HTTP client timeouts (seconds). Raise read timeout if the
# host dense/embedding model is slower; keep connect/pool lower so dead
# host endpoints fail fast.
EMBEDDING_HTTP_TIMEOUT_CONNECT_S=5.0
EMBEDDING_HTTP_TIMEOUT_READ_S=120.0
EMBEDDING_HTTP_TIMEOUT_WRITE_S=10.0
EMBEDDING_HTTP_TIMEOUT_POOL_S=10.0

# ── Dense LLM endpoint ──
DENSE_LLM_URL=http://host.docker.internal:8102/v1/chat/completions
DENSE_LLM_MODEL=dense
LLM_API_KEY=<set-or-leave-empty-for-no-auth>

SUMMARY_MAX_TOKENS=400

# ── Enriched-summary budget (tie to dense LLM's CONTEXT_SIZE) ──
SUMMARY_TOTAL_BUDGET_CHARS=100000
SUMMARY_EDGE_NEIGHBORS=10
SUMMARY_NEIGHBOR_CHARS=1200
SUMMARY_FILE_BUDGET_RATIO=0.88
SUMMARY_NEIGHBOR_BUDGET_RATIO=0.10
SUMMARY_CONTEXT_RETRY_SCALES=1.0,0.5,0.25
SUMMARY_INSTRUCTION="You are summarizing a source-code node in a project graph. Write 2-3 precise sentences: what this file does and how it connects to its neighbors. No speculation beyond the excerpts."

# ── Chat (RAG chat) ──────────────────────────────────────────────────────────
# Top-K retrieved nodes per question. Higher = more context, longer prefill.
CHAT_TOP_K=10
# Prior user+assistant turns in the prompt. Higher = better continuity,
# larger prompt cost.
CHAT_HISTORY_TURNS=6
# Prompt char budget. Keep ≤ ~3× dense LLM CONTEXT_SIZE (see
# <llm-stack>/config/models/dense.env).
CHAT_TOTAL_BUDGET_CHARS=40000
# Decode cap for answers.
CHAT_MAX_TOKENS=800
# Retry scales on HTTP-400 context-window errors (same shape as SUMMARY_*).
CHAT_CONTEXT_RETRY_SCALES=1.0,0.5,0.25
# Sampling temperature for chat answers. Lower = more deterministic.
CHAT_TEMPERATURE=0.2
# HTTP read timeout (s) for the dense LLM call. Must stay ≤ gateway's
# 115s long-LLM timeout so the gateway doesn't clip mid-flight.
CHAT_LLM_TIMEOUT_S=110.0

# ── Chat context ─────────────────────────────────────────────────
# Total tokens allowed across all included files in a single thread.
# The pipeline returns 413 when the active set exceeds this — the user
# drops files in the modal to fit. Must be ≤ <llm-stack>/
# config/models/dense.env CONTEXT_SIZE. Trade-off: larger = richer
# context + more VRAM; smaller = users drop more files to fit.
CHAT_CONTEXT_TOKEN_BUDGET=24000

# Refuse JSON export if scope resolves to more files than this.
# Trade-off: larger = giant downloads possible; smaller = monorepos
# blocked but better DX. Defaults match graph service.
EXPORT_MAX_FILES=10000

# System prompt — shell-quoted so scripts/configure.sh can source it.
# This prompt instructs the LLM to respond in plain markdown using inline
# [ref:UUID] markers instead of a JSON wrapper. Do not revert to JSON
# format — the streaming pipeline parses markers, not structured output.
CHAT_SYSTEM_INSTRUCTION="You are a code-aware assistant grounded in a knowledge graph of source files. Answer the user's question using markdown. Cite source nodes inline with [ref:UUID] markers, where UUID is exactly one of the candidate node IDs supplied in the user message context. Do not output JSON. Do not invent UUIDs. If the context doesn't support the answer, say so plainly."

# Appended to CHAT_SYSTEM_INSTRUCTION when the cite_evidence tool is
# advertised. Shell-quoted so scripts/configure.sh can source it.
CHAT_EVIDENCE_INSTRUCTION="When you reference specific code or content from a file, also call the cite_evidence function with the precise line range that supports your claim. Call it once per distinct evidence range. If you cannot identify a precise range, omit the call rather than fabricating one."

# Toggle for advertising the cite_evidence tool to the dense LLM. Flip to
# false on llama.cpp builds that 400 on the OpenAI ``tools`` request key.
CHAT_TOOLS_ENABLED=true

# Hard cap on cite_evidence rows persisted per assistant turn.
CHAT_EVIDENCE_MAX_PER_TURN=25

# Bound on the regenerate background polling loop. Must be ≥ CHAT_LLM_TIMEOUT_S.
CHAT_REGENERATE_LINK_TIMEOUT_S=130.0

# ── File reconstruction ──
FILE_RECONSTRUCT_MAX_BYTES=5242880

# ── Sparse LLM (BM25-like keyword retrieval helper) ───────────────────
# Memory: ~1 GB VRAM. Latency: ~50ms. Trade-off: false drops embedding-
# only retrieval; faster but lower recall on keyword-heavy queries.
SPARSE_LLM_URL=http://host.docker.internal:8103/v1/chat/completions
SPARSE_LLM_MODEL=sparse
# ≤ <llm-stack>/config/models/sparse.env CONTEXT_SIZE
SPARSE_LLM_CONTEXT_SIZE=16384
SPARSE_LLM_TIMEOUT_S=20
# Trade-off: more candidates → better recall, slightly slower fusion.
SPARSE_KEYWORD_TOP_K=20

# ── Reranker (cross-encoder reranking) ────────────────────────────────
# Memory: ~2 GB VRAM. Latency: ~200ms for 20 candidates. Trade-off: false
# skips cross-encoder; faster but ranking less accurate.
RERANKER_URL=http://host.docker.internal:8104/reranking
RERANKER_MODEL=reranker
# Trade-off: more final candidates → richer prompt, more tokens.
RERANKER_TOP_N=5
RERANKER_TIMEOUT_S=30
# Reciprocal rank fusion constant; higher = flatter score curve.
RERANKER_RRF_K=60

# ── Retrieval pipeline ────────────────────────────────────────────────
# Trade-off: more dense candidates → better recall, slower retrieval.
RETRIEVAL_DENSE_TOP_K=20
# Trade-off: false bypasses sparse and skips RRF fusion.
RETRIEVAL_USE_SPARSE=true
# Trade-off: false skips reranker; uses RRF top-N directly.
RETRIEVAL_USE_RERANKER=true


# ════════════════════════════════════════════════════════════════════
# ║ Ingestion tuning                                                 ║
# ╚════════════════════════════════════════════════════════════════════

CHUNK_SIZE=512
CHUNK_OVERLAP=64
FILE_SUMMARY_PREVIEW_LINES=100
AGE_BATCH_SIZE=500

# Pending-sync runner cadence / concurrency. Lower poll interval =
# faster pickup with more idle DB churn; higher batch size = more
# parallel syncs and higher DB / LLM pressure.
RUNNER_POLL_INTERVAL_S=2.0
RUNNER_CLAIM_BATCH_SIZE=5
# Shutdown grace (seconds) before in-flight syncs are cancelled.
RUNNER_SHUTDOWN_TIMEOUT_S=30.0
# Cancellation-check cadence inside the file-write loop. Lower = faster
# cancel response, more status reads.
SYNC_CANCELLATION_POLL_EVERY_N=50
# Schedule dispatch poll cadence (seconds). Lower = tighter cron latency,
# more idle DB churn.
SCHEDULER_POLL_INTERVAL_S=30

# GitHub metadata/commit lookup client sizing. Raise only if you add
# more parallel GitHub API work per sync.
GITHUB_API_MAX_CONNECTIONS=30
GITHUB_API_MAX_KEEPALIVE_CONNECTIONS=20
# GitHub HTTP timeouts (seconds). Higher read timeout tolerates slower
# API responses; lower connect/pool timeout fails fast.
GITHUB_API_TIMEOUT_CONNECT_S=5.0
GITHUB_API_TIMEOUT_READ_S=30.0
GITHUB_API_TIMEOUT_WRITE_S=10.0
GITHUB_API_TIMEOUT_POOL_S=10.0

RETENTION_ENABLED=true
RETENTION_AGE_DAYS=30
RETENTION_PER_SOURCE_CAP=10
RETENTION_TICK_INTERVAL_S=3600


# ════════════════════════════════════════════════════════════════════
# ║ Graph service — AGE reads                                        ║
# ╚════════════════════════════════════════════════════════════════════

GRAPH_QUERY_TIMEOUT_SECONDS=60

# Gateway SSE pool sizing. One live EventSource session holds one LISTEN
# connection; raise max for larger concurrent UI fan-out.
SSE_POOL_MIN_SIZE=1
SSE_POOL_MAX_SIZE=64

# Graph-service retention for append-only public.sse_events. Higher hours
# preserve replay/debug history longer but grow table size and vacuum cost.
SSE_RETENTION_ENABLED=true
SSE_RETENTION_HOURS=24
# Retention sweep cadence (seconds). Lower = faster cleanup, more churn.
SSE_RETENTION_TICK_S=3600
# Rows deleted per SQL batch in one sweep pass.
SSE_RETENTION_BATCH_SIZE=5000

# ── Per-sync Leiden (ingestion) ───────────────────────────────────
# Runs at sync completion; writes row-level stats.leiden. Fixed defaults
# intentionally — active-set carousel Leiden is configurable separately.
# See spec §4.5.
PER_SYNC_LEIDEN_ENABLED=true
PER_SYNC_LEIDEN_RESOLUTION=1.0        # more, smaller communities as this rises
PER_SYNC_LEIDEN_BETA=0.01             # refinement randomness; 0 disables
PER_SYNC_LEIDEN_ITERATIONS=10         # more iterations = more stable, slower
PER_SYNC_LEIDEN_MIN_CLUSTER_SIZE=4    # below this → "Other" bucket
PER_SYNC_LEIDEN_SEED=42               # deterministic reproduction
PER_SYNC_LEIDEN_TIMEOUT_S=30          # skip Leiden if exceeded
FINALIZE_STATS_TIMEOUT_S=15           # guard for non-Leiden stats pass

# ── Active-set Leiden (graph) ────────────────────────────────────
# On-demand carousel computation. See spec §5.6.
ACTIVE_SET_LEIDEN_ENABLED=true
ACTIVE_SET_LEIDEN_TIMEOUT_S=15          # seconds before graspologic is cancelled
ACTIVE_SET_LEIDEN_LABELING_ENABLED=true # LLM-generated community labels via dense/lazy-lamacpp
ACTIVE_SET_LEIDEN_LABEL_MODEL=dense     # lazy-lamacpp systemd unit name
LEIDEN_CACHE_TTL_HOURS=24               # cache row lifetime before TTL sweep
LEIDEN_CACHE_SWEEP_INTERVAL_S=900       # 15 min — bounded delete (LIMIT 500)
LEIDEN_CACHE_MAX_ROWS_PER_USER=20       # LRU eviction cap
LEIDEN_COMMUNITY_SAMPLE_SIZE=20         # nodes returned per CommunityEntry in /api/communities; higher = larger payload, fewer drill-down round-trips

# ── Keycloak admin (Account · Profile, P4) ─────────────────────────
# Service-account wiring for POST /api/users/me/sessions/revoke-all.
KEYCLOAK_ADMIN_URL=http://keycloak:8080/admin/realms/substrate
KEYCLOAK_TOKEN_URL=http://keycloak:8080/realms/substrate/protocol/openid-connect/token
KEYCLOAK_ADMIN_CLIENT_ID=substrate-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=           # must be set in prod; empty => /revoke-all returns 501
GITHUB_VALIDATE_TIMEOUT_S=10            # Account · Integrations probe timeout for api.github.com/user
