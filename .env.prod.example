# Production config. Copy to `.env.prod`, fill in <your-domain> + real
# secrets, then `make up MODE=prod`. TLS and hostname routing are handled
# upstream by home-stack's nginx-proxy-manager, which proxies
# app.<domain>:3535 and auth.<domain>:8080 to host.docker.internal.

# ──────── Browser-facing URLs ────────
APP_URL=https://app.<your-domain>
VITE_KEYCLOAK_URL=https://auth.<your-domain>
KEYCLOAK_ISSUER=https://auth.<your-domain>/realms/substrate
KC_HOSTNAME=https://auth.<your-domain>
KC_HOSTNAME_STRICT=true
KC_START_COMMAND=start
KC_HTTP_ENABLED=true
CORS_ORIGINS=["https://app.<your-domain>"]

# ──────── Shared ────────
KEYCLOAK_REALM=substrate
SERVICE_LOG_PRETTY=0
AUTH_DISABLED=false

# ──────── Postgres ────────
POSTGRES_VERSION=16
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=<set-a-strong-password>
GRAPH_DB_USER=substrate_graph
GRAPH_DB_PASSWORD=<set-a-strong-password>
GRAPH_DB_NAME=substrate_graph

# ──────── Keycloak ────────
KC_DB_USER=keycloak
KC_DB_PASSWORD=<set-a-strong-password>
KC_DB_NAME=keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=<set-a-strong-password>
# substrate-gateway confidential client secret; generate a long random value.
KC_GATEWAY_CLIENT_SECRET=<generate-random-secret>
# Optional GitHub identity broker — leave blank to disable.
GITHUB_OAUTH_APP_CLIENT_ID=
GITHUB_OAUTH_APP_CLIENT_SECRET=

# ──────── pgadmin ────────
PGADMIN_DEFAULT_EMAIL=admin@<your-domain>
PGADMIN_DEFAULT_PASSWORD=<set-a-strong-password>

# ──────── Local LLM endpoints (lazy-lamacpp on the host) ────────
EMBEDDING_URL=http://host.docker.internal:8101/v1/embeddings
EMBEDDING_MODEL=embeddings
EMBEDDING_DIM=896
DENSE_LLM_URL=http://host.docker.internal:8102/v1/chat/completions
DENSE_LLM_MODEL=dense
LLM_API_KEY=test
