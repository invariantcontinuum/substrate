# ╔════════════════════════════════════════════════════════════════════╗
# ║ Substrate — LOCAL / dev config                                    ║
# ║ Copy to `.env.local`, edit, then `make up` (or `make up MODE=local`)║
# ║ Every knob is read at container start — changes require a restart. ║
# ╚════════════════════════════════════════════════════════════════════╝


# ────────────── Browser-facing URLs (mode-specific) ─────────────────
APP_URL=http://localhost:3535
VITE_KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ISSUER=http://localhost:8080/realms/substrate
KC_HOSTNAME=http://localhost:8080
KC_HOSTNAME_STRICT=false
KC_START_COMMAND=start-dev
KC_HTTP_ENABLED=true
CORS_ORIGINS=["http://localhost:3535","http://localhost:3000"]


# ────────────── Shared ──────────────────────────────────────────────
KEYCLOAK_REALM=substrate
# Browser (public) Keycloak client id used by the frontend OIDC flow.
# Surfaced read-only in Settings → Authentication. Trade-off: changing
# this requires updating the matching client in the Keycloak realm
# (see scripts/render-realm.py); leave at the default unless you've
# renamed the client.
KEYCLOAK_PUBLIC_CLIENT_ID=substrate-frontend
# Optional explicit account-console URL. Leave empty to derive
# `<KEYCLOAK_ISSUER>/account/` automatically. Override only when the
# account console lives behind a different hostname than the issuer.
KEYCLOAK_ACCOUNT_CONSOLE_URL=
SERVICE_LOG_PRETTY=0
# Set to `true` only in dev to short-circuit JWT validation at the
# gateway (emits stub admin claims). Must be `false` in prod.
AUTH_DISABLED=false


# ────────────── Postgres (single DB: substrate_graph) ───────────────
POSTGRES_VERSION=16
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change-me
GRAPH_DB_USER=substrate_graph
GRAPH_DB_PASSWORD=change-me
GRAPH_DB_NAME=substrate_graph

# ── Graph service connection (Settings → Postgres surfaces these) ──
# Discrete connection fields used by the graph service to compose its
# asyncpg DSN at startup. Change a credential here to rotate; the
# panel writes the same keys via runtime_config so a UI edit survives
# container restart. Pool tunables trade memory/throughput vs DB
# session usage — defaults match a single-host dev box.
PG_POOL_MIN_SIZE=2                 # pinned conns: faster cold-start, more idle resource
PG_POOL_MAX_SIZE=25                # ceiling under bursty load; raise if you see "queue full"
PG_POOL_RECYCLE_SECONDS=1800       # idle conn TTL; lower to react faster to credential rotation
PG_STATEMENT_TIMEOUT_MS=60000      # cap on a single SQL — protects against runaway AGE plans
PG_LOCK_TIMEOUT_MS=5000            # max wait on row/relation locks before bailing
PG_SSL_VERIFY=true                 # require TLS + verify cert; false only inside trusted network


# ────────────── Keycloak ────────────────────────────────────────────
KC_DB_USER=keycloak
KC_DB_PASSWORD=change-me
KC_DB_NAME=keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me
# Allow local self-service registration by default so dev can validate
# first-login flows without manually creating each user in admin UI.
KEYCLOAK_REGISTRATION_ALLOWED=true
# substrate-gateway confidential client secret — rendered into the
# realm JSON by scripts/render-realm.py at every `make up`. Rotate by
# editing here, then `make up && make nuke-keycloak`.
KC_GATEWAY_CLIENT_SECRET=change-me
# Optional GitHub identity broker — blank disables the GitHub IdP.
GITHUB_OAUTH_APP_CLIENT_ID=
GITHUB_OAUTH_APP_CLIENT_SECRET=

# ────────────── Gateway: API tokens (PATs) ──────────────────────────
# Personal access tokens consumed by the bearer-auth fast-path in the
# gateway. Trade-off: shorter random body = easier brute force; longer
# = more clipboard awkward. 24 url-safe bytes ≈ 192 bits entropy.
API_TOKEN_PLAINTEXT_PREFIX=subs_
API_TOKEN_RANDOM_BYTES=24      # secrets.token_urlsafe(N) -> ~⌈4N/3⌉ chars
API_TOKEN_DISPLAY_PREFIX_LEN=8 # chars shown in the UI list to disambiguate


# ────────────── pgadmin ─────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@substrate.dev
PGADMIN_DEFAULT_PASSWORD=change-me


# ════════════════════════════════════════════════════════════════════
# ║ AI / LLM configuration                                           ║
# ║ The defaults below pair with lazy-lamacpp's current served models.║
# ║ Swapping models? Update (a) the model's env file under           ║
# ║ <llm-stack>/config/models/<name>.env and (b) the        ║
# ║ matching knobs here so context-window budgets stay honest.       ║
# ╚════════════════════════════════════════════════════════════════════

# ────────────── Embedding LLM endpoint ──────────────────────────────
# Per-role connection knobs. The Settings → LLM Connections panel reads
# and writes these via PUT /api/config/llm_embedding using simple field
# names (`name`, `url`, `api_key`, `context_window_tokens`, `timeout_s`,
# `ssl_verify`); the gateway translates to the storage keys below.
EMBEDDING_URL=http://host.docker.internal:8101/v1/embeddings
# lazy-lamacpp exposes models by systemd-unit name, not HF path.
EMBEDDING_MODEL=embeddings
# Bearer token sent on the embedding endpoint. Empty = no Authorization
# header. Trade-off: only used by the embedding role; dense / sparse /
# reranker each have their own per-role api_key below.
EMBEDDING_API_KEY=test
# Verify upstream TLS certificate for the embedding endpoint. Set to
# false only for self-signed local proxies — has no effect on plain
# http:// URLs.
EMBEDDING_SSL_VERIFY=true
# Read budget (seconds) for one embedding HTTP call. Trade-off: higher
# = tolerates slow host LLM batches; lower = faster failure on a dead
# endpoint. Independently tunable from EMBEDDING_HTTP_TIMEOUT_READ_S
# below — that knob bounds the ingestion-side per-batch budget; this
# one is the panel's connection timeout and is also reused by the
# /api/llm/embedding/test probe.
EMBEDDING_TIMEOUT_S=30.0
# ≤ <llm-stack>/config/models/embeddings.env CONTEXT_SIZE.
# Drives EMBEDDING_MAX_INPUT_CHARS sanity-check for very long inputs.
EMBEDDING_CONTEXT_WINDOW_TOKENS=8192
# MUST match the pgvector column dim — `vector(N)` in the latest
# V*__embedding_dim_*.sql migration. Startup guard fails fast on
# mismatch; swapping models usually requires a new migration.
EMBEDDING_DIM=768
# Prefix scheme for this model. jina-code-embeddings uses
# "search_document: " / "search_query: ". E5 uses "passage:" / "query:".
# BGE uses no prefix (set both to empty strings).
EMBEDDING_DOCUMENT_PREFIX=search_document:
EMBEDDING_QUERY_PREFIX=search_query:
# Hard cap on each per-input payload sent to the embedding server,
# including the prefix. At ~3 chars/token, 1400 chars ≈ 470 tokens,
# safe for any embedding model with ≥ 512-token context. Raise when
# switching to a larger-context embedding model (jina-code-0.5b
# supports 32768) to reduce truncation-driven quality loss.
EMBEDDING_MAX_INPUT_CHARS=1400
# Inputs per embedding HTTP call. Larger = fewer round-trips, but
# worse bisect granularity if one input is a poison pill.
EMBED_BATCH_SIZE=32
# Embedding HTTP client timeouts (seconds). Raise read timeout if
# host-side lazy-lamacpp batches take longer; keep connect/pool lower
# for faster failure on a dead local model.
EMBEDDING_HTTP_TIMEOUT_CONNECT_S=5.0
EMBEDDING_HTTP_TIMEOUT_READ_S=120.0
EMBEDDING_HTTP_TIMEOUT_WRITE_S=10.0
EMBEDDING_HTTP_TIMEOUT_POOL_S=10.0


# ────────────── Dense LLM endpoint (chat + summaries) ──────────────
# Per-role connection knobs. The Settings → LLM Connections panel reads
# and writes these via PUT /api/config/llm_dense using simple field
# names (`name`, `url`, `api_key`, `context_window_tokens`, `timeout_s`,
# `ssl_verify`); the gateway translates to the storage keys below.
DENSE_LLM_URL=http://host.docker.internal:8102/v1/chat/completions
DENSE_LLM_MODEL=dense
# Bearer token sent on the dense LLM endpoint (chat + summary + community
# labelling all share this credential). Empty = no Authorization header.
DENSE_LLM_API_KEY=test
# Verify upstream TLS certificate for the dense LLM endpoint. Set to
# false only for self-signed local proxies; ignored on plain http://.
DENSE_LLM_SSL_VERIFY=true
# ≤ <llm-stack>/config/models/dense.env CONTEXT_SIZE. Drives
# SUMMARY_TOTAL_BUDGET_CHARS / CHAT_TOTAL_BUDGET_CHARS / CHAT_CONTEXT_TOKEN_BUDGET
# sanity — anything ≤ 3× this is safe at the ~3-chars-per-token heuristic.
DENSE_LLM_CONTEXT_SIZE=60000
# HTTP read timeout (s) for the dense LLM call. Must stay ≤ gateway's
# 115s long-LLM timeout so the gateway doesn't clip mid-flight.
# Trade-off: higher = chat answers ride out a slow first-token; lower =
# faster failure on a stuck model.
DENSE_LLM_TIMEOUT_S=110.0

# Max output tokens allowed in a summary response. Tune to match the
# SUMMARY_INSTRUCTION target length (the default system prompt asks
# for 2-3 sentences, roughly 300-400 tokens).
SUMMARY_MAX_TOKENS=400

# ── Enriched-summary prompt budget ──
# Total prompt char budget. SHOULD be ≤ 3 × (CONTEXT_SIZE in
# <llm-stack>/config/models/dense.env) — the ~3 chars/token
# heuristic. With Qwen3.5-2B at 60 416 tokens context, 100 000 chars
# ≈ 33 k tokens leaves room for system prompt + decode. Raise with a
# larger-context dense model; lower if prefill times feel too slow.
SUMMARY_TOTAL_BUDGET_CHARS=100000
# Top-K edge neighbors included in the prompt. Higher = more graph
# context, longer prefill; lower = faster summaries with thinner
# cross-file reasoning.
SUMMARY_EDGE_NEIGHBORS=10
# Per-neighbor char cap (single neighbor's description + first lines).
SUMMARY_NEIGHBOR_CHARS=1200
# Portion of SUMMARY_TOTAL_BUDGET_CHARS spent on the source file body.
SUMMARY_FILE_BUDGET_RATIO=0.88
# Portion spent on the top-K neighbor block in aggregate. The
# remainder (1 - file - neighbor) is reserved for system prompt and
# section headers.
SUMMARY_NEIGHBOR_BUDGET_RATIO=0.10
# Context-overflow retry scales. Comma-separated floats, applied in
# order when the dense LLM returns HTTP 400 with a
# context-window-exceeded error. After exhausting the list the
# pipeline returns source="llm_failed" instead of raising.
SUMMARY_CONTEXT_RETRY_SCALES=1.0,0.5,0.25
# Exact system-prompt text sent as the `system` message. Shapes every
# summary — keep task-focused, model-agnostic, and terse.
SUMMARY_INSTRUCTION="You are summarizing a source-code node in a project graph. Write 2-3 precise sentences: what this file does and how it connects to its neighbors. No speculation beyond the excerpts."

# ── Chat (RAG chat) ──────────────────────────────────────────────────────────
# Top-K retrieved nodes per question. Higher = more context, longer prefill.
CHAT_TOP_K=10
# Prior user+assistant turns in the prompt. Higher = better continuity,
# larger prompt cost.
CHAT_HISTORY_TURNS=6
# Prompt char budget. Keep ≤ ~3× dense LLM CONTEXT_SIZE (see
# <llm-stack>/config/models/dense.env).
CHAT_TOTAL_BUDGET_CHARS=40000
# Decode cap for answers.
CHAT_MAX_TOKENS=800
# Retry scales on HTTP-400 context-window errors (same shape as SUMMARY_*).
CHAT_CONTEXT_RETRY_SCALES=1.0,0.5,0.25
# Sampling temperature for chat answers. Lower = more deterministic.
CHAT_TEMPERATURE=0.2

# ── Chat context ─────────────────────────────────────────────────
# Total tokens allowed across all included files in a single thread.
# The pipeline returns 413 when the active set exceeds this — the user
# drops files in the modal to fit. Must be ≤ <llm-stack>/
# config/models/dense.env CONTEXT_SIZE. Trade-off: larger = richer
# context + more VRAM; smaller = users drop more files to fit.
CHAT_CONTEXT_TOKEN_BUDGET=24000

# Refuse JSON export if scope resolves to more files than this.
# Trade-off: larger = giant downloads possible; smaller = monorepos
# blocked but better DX. Defaults match graph service.
EXPORT_MAX_FILES=10000

# System prompt — shell-quoted so scripts/configure.sh can source it.
# This prompt instructs the LLM to respond in plain markdown using inline
# [ref:UUID] markers instead of a JSON wrapper. Do not revert to JSON
# format — the streaming pipeline parses markers, not structured output.
CHAT_SYSTEM_INSTRUCTION="You are a code-aware assistant grounded in a knowledge graph of source files. Answer the user's question using markdown. Cite source nodes inline with [ref:UUID] markers, where UUID is exactly one of the candidate node IDs supplied in the user message context. Do not output JSON. Do not invent UUIDs. If the context doesn't support the answer, say so plainly."

# Appended to CHAT_SYSTEM_INSTRUCTION when the cite_evidence tool is
# advertised. Asks the LLM to call cite_evidence with precise line ranges
# whenever it quotes or paraphrases a specific code range.
# Shell-quoted so scripts/configure.sh can source it.
CHAT_EVIDENCE_INSTRUCTION="When you reference specific code or content from a file, also call the cite_evidence function with the precise line range that supports your claim. Call it once per distinct evidence range. If you cannot identify a precise range, omit the call rather than fabricating one."

# Toggle for advertising the cite_evidence tool to the dense LLM. Set to
# false on llama.cpp builds that 400 on the OpenAI ``tools`` request key
# — the regex fallback will still parse [CITE …] inline markers from
# the assistant text. Trade-off: tool path is schema-validated but
# requires a recent llama.cpp; regex fallback works everywhere but
# tolerates more LLM mistakes.
CHAT_TOOLS_ENABLED=true

# Hard cap on cite_evidence rows persisted per assistant turn (caps
# write-storm if the model emits many spurious calls). Trade-off: higher
# = richer evidence; lower = tighter floor on storage + UI rendering cost.
CHAT_EVIDENCE_MAX_PER_TURN=25
# Max chars of the first-chunk excerpt shown per cited node in tool-call
# file expansion. Trade-off: larger = richer context, more tokens; smaller
# = more nodes fit in the same budget. Should be ≤ CHAT_TOTAL_BUDGET_CHARS / CHAT_TOP_K.
CHAT_EXCERPT_MAX_CHARS=1200

# Bound on the regenerate background polling loop that links a
# superseded assistant row to its replacement once stream_turn writes
# the new chat_messages row. Must be ≥ DENSE_LLM_TIMEOUT_S so a slow
# but successful stream still gets linked.
CHAT_REGENERATE_LINK_TIMEOUT_S=130.0

# ── File reconstruction ──
# Byte cap on /api/graph/nodes/{id}/file reconstructed content. Files
# exceeding this raise FileTooLargeForReconstruct (→ HTTP 413).
# Trade-off: memory (per request) vs. ability to load full source for large files.
FILE_RECONSTRUCT_MAX_BYTES=16777216

# System default for sliding-window chat history (turns).
# 1 turn = 1 user message + 1 assistant message = 2 messages.
# Per-user override stored in user_profiles.chat_settings.history_turns.
# Trade-off: prompt size vs context recall.
CHAT_HISTORY_TURNS_DEFAULT=12

# Cap on AGE neighborhood traversal depth-N expansion.
# Trade-off: prompt size vs graph reach.
CHAT_NODE_NEIGHBORHOOD_MAX_NODES=200

# ── Sparse LLM (BM25-like keyword retrieval helper) ───────────────────
# Per-role connection knobs. The Settings → LLM Connections panel reads
# and writes these via PUT /api/config/llm_sparse using simple field
# names; the gateway translates to the storage keys below.
# Memory: ~1 GB VRAM. Latency: ~50ms. Trade-off: false drops embedding-
# only retrieval; faster but lower recall on keyword-heavy queries.
SPARSE_LLM_URL=http://host.docker.internal:8103/v1/chat/completions
SPARSE_LLM_MODEL=sparse
SPARSE_LLM_API_KEY=test
SPARSE_LLM_SSL_VERIFY=true
# ≤ <llm-stack>/config/models/sparse.env CONTEXT_SIZE
SPARSE_LLM_CONTEXT_SIZE=16384
SPARSE_LLM_TIMEOUT_S=20
# Trade-off: more candidates → better recall, slightly slower fusion.
SPARSE_KEYWORD_TOP_K=20

# ── Reranker (cross-encoder reranking) ────────────────────────────────
# Per-role connection knobs (see PUT /api/config/llm_reranker).
# Memory: ~2 GB VRAM. Latency: ~200ms for 20 candidates. Trade-off: false
# skips cross-encoder; faster but ranking less accurate.
RERANKER_URL=http://host.docker.internal:8104/reranking
RERANKER_MODEL=reranker
RERANKER_API_KEY=test
RERANKER_SSL_VERIFY=true
# Reranker model context window (tokens). Used by the panel for sanity
# only — the cross-encoder itself takes per-request limits set inline.
RERANKER_CONTEXT_WINDOW_TOKENS=8192
# Trade-off: more final candidates → richer prompt, more tokens.
RERANKER_TOP_N=5
RERANKER_TIMEOUT_S=30
# Reciprocal rank fusion constant; higher = flatter score curve.
RERANKER_RRF_K=60
# Max chars of candidate text (description or file_path) sent to the reranker
# per document. Trade-off: larger = better ranking signal, more tokens per
# candidate; smaller = faster reranker, slightly lower quality.
# Should be ≤ RERANKER_CONTEXT_WINDOW_TOKENS × 3 chars/token.
RERANKER_DOC_TEXT_MAX_CHARS=2000

# ── Retrieval pipeline ────────────────────────────────────────────────
# Trade-off: more dense candidates → better recall, slower retrieval.
RETRIEVAL_DENSE_TOP_K=20
# Trade-off: false bypasses sparse and skips RRF fusion.
RETRIEVAL_USE_SPARSE=true
# Trade-off: false skips reranker; uses RRF top-N directly.
RETRIEVAL_USE_RERANKER=true


# ════════════════════════════════════════════════════════════════════
# ║ Ingestion tuning                                                 ║
# ╚════════════════════════════════════════════════════════════════════

# ── Chunker ──
# Target tokens per chunk produced by substrate-graph-builder.chunker.
# Must be ≤ the embedding model's context (minus prefix + breadcrumb
# header). Too small = more chunks + more embed calls; too large =
# wasted context on generic block padding.
CHUNK_SIZE=512
# Token overlap between adjacent chunks. Only applied in the
# markdown / text / line-greedy fallback paths — AST chunks rely on
# contextual breadcrumbs instead of raw overlap.
CHUNK_OVERLAP=64
# Lines of file body prepended to the file-summary string that gets
# embedded into file_embeddings.embedding. Higher = richer file-level
# vectors, but more aggressive truncation after the 1400-char cap.
FILE_SUMMARY_PREVIEW_LINES=100

# ── AGE batch size ──
# Rows per UNWIND batch when writing nodes/edges. Smaller = more SQL
# round-trips; larger = bigger transaction rollback window on failure.
AGE_BATCH_SIZE=500

# ── Runner / scheduler loops ──
# Pending-sync poll cadence. Lower = faster pickup, more idle DB churn.
RUNNER_POLL_INTERVAL_S=2.0
# Pending rows claimed per tick. Higher = more parallel syncs, more DB
# / LLM pressure across the single `substrate_graph` boundary.
RUNNER_CLAIM_BATCH_SIZE=5
# Shutdown grace before in-flight sync tasks are cancelled. Higher =
# gentler stop, slower restarts.
RUNNER_SHUTDOWN_TIMEOUT_S=30.0
# Cancellation-check cadence inside the per-file graph write loop.
# Lower = faster cancel response, more DB status reads.
SYNC_CANCELLATION_POLL_EVERY_N=50
# Schedule dispatch poll cadence. Lower = tighter cron latency, more
# idle DB churn.
SCHEDULER_POLL_INTERVAL_S=30

# ── GitHub API client ──
# Pool sizing for repo metadata / commit lookups. Raise only if you add
# more parallel GitHub API work per sync.
GITHUB_API_MAX_CONNECTIONS=30
GITHUB_API_MAX_KEEPALIVE_CONNECTIONS=20
# GitHub HTTP timeouts (seconds). Higher read timeout tolerates slower
# API responses; lower connect/pool timeout fails fast on network issues.
GITHUB_API_TIMEOUT_CONNECT_S=5.0
GITHUB_API_TIMEOUT_READ_S=30.0
GITHUB_API_TIMEOUT_WRITE_S=10.0
GITHUB_API_TIMEOUT_POOL_S=10.0

# ── Sync issue recording ──
# Hard cap on issues stored per sync run. Exceeding it increments
# stats.issues_suppressed and inserts a single truncation_marker row.
# Trade-off: larger = more debug detail; smaller = leaner table but early
# truncation on noisy connectors.
SYNC_ISSUE_CAP=1000

# ── Retention ──
RETENTION_ENABLED=true
# Sync runs older than this many days are eligible for cleanup.
RETENTION_AGE_DAYS=30
# Keep at most this many most-recent completed syncs per source,
# regardless of age.
RETENTION_PER_SOURCE_CAP=10
# Retention sweep interval (seconds).
RETENTION_TICK_INTERVAL_S=3600


# ════════════════════════════════════════════════════════════════════
# ║ Graph service — AGE reads                                        ║
# ╚════════════════════════════════════════════════════════════════════

# Wall-clock cap for merged-graph Cypher queries (seconds). Guards
# against a stuck AGE plan saturating the asyncpg pool.
GRAPH_QUERY_TIMEOUT_SECONDS=60

# SSE connection pool in gateway. One active EventSource client keeps one
# LISTEN connection open; raise max for higher concurrent dashboard viewers.
SSE_POOL_MIN_SIZE=1
SSE_POOL_MAX_SIZE=64

# SSE event-log retention in graph service. Keep this in sync with your
# operational replay/debug horizon: higher values keep more history but
# grow public.sse_events and vacuum work.
SSE_RETENTION_ENABLED=true
SSE_RETENTION_HOURS=24
# Prune interval in seconds. Lower = fresher table, more delete churn.
SSE_RETENTION_TICK_S=3600
# Delete batch size per SQL round. Higher = fewer round-trips, longer lock.
SSE_RETENTION_BATCH_SIZE=5000

# ── Per-sync Leiden (ingestion) ───────────────────────────────────
# Runs at sync completion; writes row-level stats.leiden. Fixed defaults
# intentionally — active-set carousel Leiden is configurable separately.
# See spec §4.5.
PER_SYNC_LEIDEN_ENABLED=true
PER_SYNC_LEIDEN_RESOLUTION=1.0        # more, smaller communities as this rises
PER_SYNC_LEIDEN_BETA=0.01             # refinement randomness; 0 disables
PER_SYNC_LEIDEN_ITERATIONS=10         # more iterations = more stable, slower
PER_SYNC_LEIDEN_MIN_CLUSTER_SIZE=4    # below this → "Other" bucket
PER_SYNC_LEIDEN_SEED=42               # deterministic reproduction
PER_SYNC_LEIDEN_TIMEOUT_S=30          # skip Leiden if exceeded
FINALIZE_STATS_TIMEOUT_S=15           # guard for non-Leiden stats pass

# ── Active-set Leiden (graph) ────────────────────────────────────
# On-demand carousel computation. See spec §5.6.
ACTIVE_SET_LEIDEN_ENABLED=true
ACTIVE_SET_LEIDEN_TIMEOUT_S=15          # seconds before graspologic is cancelled
ACTIVE_SET_LEIDEN_LABELING_ENABLED=true # LLM-generated community labels via dense/lazy-lamacpp
ACTIVE_SET_LEIDEN_LABEL_MODEL=dense     # lazy-lamacpp systemd unit name
LEIDEN_CACHE_TTL_HOURS=24               # cache row lifetime before TTL sweep
LEIDEN_CACHE_SWEEP_INTERVAL_S=900       # 15 min — bounded delete (LIMIT 500)
LEIDEN_CACHE_MAX_ROWS_PER_USER=20       # LRU eviction cap
LEIDEN_COMMUNITY_SAMPLE_SIZE=20         # nodes returned per CommunityEntry in /api/communities; higher = larger payload, fewer drill-down round-trips

# ── Keycloak admin (Account · Profile, P4) ─────────────────────────
# Service-account wiring for POST /api/users/me/sessions/revoke-all.
# Empty secret => endpoint returns 501 so unconfigured dev loops fail loudly.
KEYCLOAK_ADMIN_URL=http://keycloak:8080/admin/realms/substrate
KEYCLOAK_TOKEN_URL=http://keycloak:8080/realms/substrate/protocol/openid-connect/token
KEYCLOAK_ADMIN_CLIENT_ID=substrate-gateway
GITHUB_VALIDATE_TIMEOUT_S=10            # Account · Integrations probe timeout for api.github.com/user

# ────────────── 2FA TOTP ─────────────────────────────────────────────
# Issuer label embedded in the otpauth:// URL — what authenticator apps
# show next to the account name. Trade-off: longer = more recognisable,
# more screen space; keep ≤ 16 chars to avoid wrapping.
TOTP_ISSUER=Substrate

# ────────────── Avatar upload ────────────────────────────────────────
# Hard cap on raw avatar upload bytes before Pillow opens the file.
# Trade-off: higher = phone-camera PNGs accepted (typically 1–3 MiB);
# lower = less peak buffering per concurrent upload. Must NOT exceed
# the reverse-proxy upstream cap (~5 MiB by default).
AVATAR_MAX_UPLOAD_BYTES=4194304
# Stored avatar edge length after centre-crop + resize. Trade-off:
# larger = sharper retina avatars, more BYTEA per row; smaller = visible
# blur in retina headers.
AVATAR_TARGET_SIZE_PX=256
# Cache lifetime hint (seconds) on GET /api/users/me/avatar. Trade-off:
# short = upload propagates quickly to other tabs; long = browser
# doesn't re-fetch on every page nav.
AVATAR_CACHE_MAX_AGE_S=60
