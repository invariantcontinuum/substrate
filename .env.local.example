# ╔════════════════════════════════════════════════════════════════════╗
# ║ Substrate — LOCAL / dev config                                    ║
# ║ Copy to `.env.local`, edit, then `make up` (or `make up MODE=local`)║
# ║ Every knob is read at container start — changes require a restart. ║
# ╚════════════════════════════════════════════════════════════════════╝


# ────────────── Browser-facing URLs (mode-specific) ─────────────────
APP_URL=http://localhost:3535
VITE_KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ISSUER=http://localhost:8080/realms/substrate
KC_HOSTNAME=http://localhost:8080
KC_HOSTNAME_STRICT=false
KC_START_COMMAND=start-dev
KC_HTTP_ENABLED=true
CORS_ORIGINS=["http://localhost:3535","http://localhost:3000"]


# ────────────── Shared ──────────────────────────────────────────────
KEYCLOAK_REALM=substrate
SERVICE_LOG_PRETTY=0
# Set to `true` only in dev to short-circuit JWT validation at the
# gateway (emits stub admin claims). Must be `false` in prod.
AUTH_DISABLED=false


# ────────────── Postgres (single DB: substrate_graph) ───────────────
POSTGRES_VERSION=16
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change-me
GRAPH_DB_USER=substrate_graph
GRAPH_DB_PASSWORD=change-me
GRAPH_DB_NAME=substrate_graph


# ────────────── Keycloak ────────────────────────────────────────────
KC_DB_USER=keycloak
KC_DB_PASSWORD=change-me
KC_DB_NAME=keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me
# Allow local self-service registration by default so dev can validate
# first-login flows without manually creating each user in admin UI.
KEYCLOAK_REGISTRATION_ALLOWED=true
# substrate-gateway confidential client secret — rendered into the
# realm JSON by scripts/render-realm.py at every `make up`. Rotate by
# editing here, then `make up && make nuke-keycloak`.
KC_GATEWAY_CLIENT_SECRET=change-me
# Optional GitHub identity broker — blank disables the GitHub IdP.
GITHUB_OAUTH_APP_CLIENT_ID=
GITHUB_OAUTH_APP_CLIENT_SECRET=


# ────────────── pgadmin ─────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@substrate.dev
PGADMIN_DEFAULT_PASSWORD=change-me


# ════════════════════════════════════════════════════════════════════
# ║ AI / LLM configuration                                           ║
# ║ The defaults below pair with lazy-lamacpp's current served models.║
# ║ Swapping models? Update (a) the model's env file under           ║
# ║ ops/llm/lazy-lamacpp/config/models/<name>.env and (b) the        ║
# ║ matching knobs here so context-window budgets stay honest.       ║
# ╚════════════════════════════════════════════════════════════════════

# ────────────── Embedding LLM endpoint ──────────────────────────────
EMBEDDING_URL=http://host.docker.internal:8101/v1/embeddings
# lazy-lamacpp exposes models by systemd-unit name, not HF path.
EMBEDDING_MODEL=embeddings
# MUST match the pgvector column dim — `vector(N)` in the latest
# V*__embedding_dim_*.sql migration. Startup guard fails fast on
# mismatch; swapping models usually requires a new migration.
EMBEDDING_DIM=768
# Prefix scheme for this model. jina-code-embeddings uses
# "search_document: " / "search_query: ". E5 uses "passage:" / "query:".
# BGE uses no prefix (set both to empty strings).
EMBEDDING_DOCUMENT_PREFIX=search_document:
EMBEDDING_QUERY_PREFIX=search_query:
# Hard cap on each per-input payload sent to the embedding server,
# including the prefix. At ~3 chars/token, 1400 chars ≈ 470 tokens,
# safe for any embedding model with ≥ 512-token context. Raise when
# switching to a larger-context embedding model (jina-code-0.5b
# supports 32768) to reduce truncation-driven quality loss.
EMBEDDING_MAX_INPUT_CHARS=1400
# Inputs per embedding HTTP call. Larger = fewer round-trips, but
# worse bisect granularity if one input is a poison pill.
EMBED_BATCH_SIZE=32
# Embedding HTTP client timeouts (seconds). Raise read timeout if
# host-side lazy-lamacpp batches take longer; keep connect/pool lower
# for faster failure on a dead local model.
EMBEDDING_HTTP_TIMEOUT_CONNECT_S=5.0
EMBEDDING_HTTP_TIMEOUT_READ_S=120.0
EMBEDDING_HTTP_TIMEOUT_WRITE_S=10.0
EMBEDDING_HTTP_TIMEOUT_POOL_S=10.0


# ────────────── Dense LLM endpoint (for summaries) ──────────────────
DENSE_LLM_URL=http://host.docker.internal:8102/v1/chat/completions
DENSE_LLM_MODEL=dense
# Bearer token shared by both endpoints. Empty value skips the
# Authorization header entirely (useful with unauthenticated llama.cpp
# servers).
LLM_API_KEY=test

# Max output tokens allowed in a summary response. Tune to match the
# SUMMARY_INSTRUCTION target length (the default system prompt asks
# for 2-3 sentences, roughly 300-400 tokens).
SUMMARY_MAX_TOKENS=400

# ── Enriched-summary prompt budget ──
# Total prompt char budget. SHOULD be ≤ 3 × (CONTEXT_SIZE in
# ops/llm/lazy-lamacpp/config/models/dense.env) — the ~3 chars/token
# heuristic. With Qwen3.5-2B at 60 416 tokens context, 100 000 chars
# ≈ 33 k tokens leaves room for system prompt + decode. Raise with a
# larger-context dense model; lower if prefill times feel too slow.
SUMMARY_TOTAL_BUDGET_CHARS=100000
# Top-K edge neighbors included in the prompt. Higher = more graph
# context, longer prefill; lower = faster summaries with thinner
# cross-file reasoning.
SUMMARY_EDGE_NEIGHBORS=10
# Per-neighbor char cap (single neighbor's description + first lines).
SUMMARY_NEIGHBOR_CHARS=1200
# Portion of SUMMARY_TOTAL_BUDGET_CHARS spent on the source file body.
SUMMARY_FILE_BUDGET_RATIO=0.88
# Portion spent on the top-K neighbor block in aggregate. The
# remainder (1 - file - neighbor) is reserved for system prompt and
# section headers.
SUMMARY_NEIGHBOR_BUDGET_RATIO=0.10
# Context-overflow retry scales. Comma-separated floats, applied in
# order when the dense LLM returns HTTP 400 with a
# context-window-exceeded error. After exhausting the list the
# pipeline returns source="llm_failed" instead of raising.
SUMMARY_CONTEXT_RETRY_SCALES=1.0,0.5,0.25
# Exact system-prompt text sent as the `system` message. Shapes every
# summary — keep task-focused, model-agnostic, and terse.
SUMMARY_INSTRUCTION="You are summarizing a source-code node in a project graph. Write 2-3 precise sentences: what this file does and how it connects to its neighbors. No speculation beyond the excerpts."

# ── Ask (RAG chat) ──────────────────────────────────────────────────────────
# Top-K retrieved nodes per question. Higher = more context, longer prefill.
ASK_TOP_K=10
# Prior user+assistant turns in the prompt. Higher = better continuity,
# larger prompt cost.
ASK_HISTORY_TURNS=6
# Prompt char budget. Keep ≤ ~3× dense LLM CONTEXT_SIZE (see
# ops/llm/lazy-lamacpp/config/models/dense.env).
ASK_TOTAL_BUDGET_CHARS=40000
# Decode cap for answers.
ASK_MAX_TOKENS=800
# Retry scales on HTTP-400 context-window errors (same shape as SUMMARY_*).
ASK_CONTEXT_RETRY_SCALES=1.0,0.5,0.25
# Sampling temperature for ask answers. Lower = more deterministic.
ASK_TEMPERATURE=0.2
# HTTP read timeout (s) for the dense LLM call. Must stay ≤ gateway's
# 115s long-LLM timeout so the gateway doesn't clip mid-flight.
ASK_LLM_TIMEOUT_S=110.0
# System prompt — shell-quoted so scripts/configure.sh can source it.
ASK_SYSTEM_INSTRUCTION="You are answering questions about a codebase knowledge graph. Use ONLY the node context provided below; if the answer is not supported by that context, say so plainly. Respond as a single JSON object: {\"answer\": \"<prose>\", \"cited_node_ids\": [\"<id1>\", ...]}. Keep the answer to 1-3 short paragraphs. Cite every node you actually used."

# ── File reconstruction ──
# Byte cap on /api/graph/nodes/{id}/file reconstructed content. Files
# exceeding this are returned with truncated=true. Higher = more
# request memory; lower = more frequent truncation.
FILE_RECONSTRUCT_MAX_BYTES=5242880


# ════════════════════════════════════════════════════════════════════
# ║ Ingestion tuning                                                 ║
# ╚════════════════════════════════════════════════════════════════════

# ── Chunker ──
# Target tokens per chunk produced by substrate-graph-builder.chunker.
# Must be ≤ the embedding model's context (minus prefix + breadcrumb
# header). Too small = more chunks + more embed calls; too large =
# wasted context on generic block padding.
CHUNK_SIZE=512
# Token overlap between adjacent chunks. Only applied in the
# markdown / text / line-greedy fallback paths — AST chunks rely on
# contextual breadcrumbs instead of raw overlap.
CHUNK_OVERLAP=64
# Lines of file body prepended to the file-summary string that gets
# embedded into file_embeddings.embedding. Higher = richer file-level
# vectors, but more aggressive truncation after the 1400-char cap.
FILE_SUMMARY_PREVIEW_LINES=100

# ── AGE batch size ──
# Rows per UNWIND batch when writing nodes/edges. Smaller = more SQL
# round-trips; larger = bigger transaction rollback window on failure.
AGE_BATCH_SIZE=500

# ── Runner / scheduler loops ──
# Pending-sync poll cadence. Lower = faster pickup, more idle DB churn.
RUNNER_POLL_INTERVAL_S=2.0
# Pending rows claimed per tick. Higher = more parallel syncs, more DB
# / LLM pressure across the single `substrate_graph` boundary.
RUNNER_CLAIM_BATCH_SIZE=5
# Shutdown grace before in-flight sync tasks are cancelled. Higher =
# gentler stop, slower restarts.
RUNNER_SHUTDOWN_TIMEOUT_S=30.0
# Cancellation-check cadence inside the per-file graph write loop.
# Lower = faster cancel response, more DB status reads.
SYNC_CANCELLATION_POLL_EVERY_N=50
# Schedule dispatch poll cadence. Lower = tighter cron latency, more
# idle DB churn.
SCHEDULER_POLL_INTERVAL_S=30

# ── GitHub API client ──
# Pool sizing for repo metadata / commit lookups. Raise only if you add
# more parallel GitHub API work per sync.
GITHUB_API_MAX_CONNECTIONS=30
GITHUB_API_MAX_KEEPALIVE_CONNECTIONS=20
# GitHub HTTP timeouts (seconds). Higher read timeout tolerates slower
# API responses; lower connect/pool timeout fails fast on network issues.
GITHUB_API_TIMEOUT_CONNECT_S=5.0
GITHUB_API_TIMEOUT_READ_S=30.0
GITHUB_API_TIMEOUT_WRITE_S=10.0
GITHUB_API_TIMEOUT_POOL_S=10.0

# ── Retention ──
RETENTION_ENABLED=true
# Sync runs older than this many days are eligible for cleanup.
RETENTION_AGE_DAYS=30
# Keep at most this many most-recent completed syncs per source,
# regardless of age.
RETENTION_PER_SOURCE_CAP=10
# Retention sweep interval (seconds).
RETENTION_TICK_INTERVAL_S=3600


# ════════════════════════════════════════════════════════════════════
# ║ Graph service — AGE reads                                        ║
# ╚════════════════════════════════════════════════════════════════════

# Wall-clock cap for merged-graph Cypher queries (seconds). Guards
# against a stuck AGE plan saturating the asyncpg pool.
GRAPH_QUERY_TIMEOUT_SECONDS=60

# SSE connection pool in gateway. One active EventSource client keeps one
# LISTEN connection open; raise max for higher concurrent dashboard viewers.
SSE_POOL_MIN_SIZE=1
SSE_POOL_MAX_SIZE=64

# SSE event-log retention in graph service. Keep this in sync with your
# operational replay/debug horizon: higher values keep more history but
# grow public.sse_events and vacuum work.
SSE_RETENTION_ENABLED=true
SSE_RETENTION_HOURS=24
# Prune interval in seconds. Lower = fresher table, more delete churn.
SSE_RETENTION_TICK_S=3600
# Delete batch size per SQL round. Higher = fewer round-trips, longer lock.
SSE_RETENTION_BATCH_SIZE=5000

# ── Per-sync Leiden (ingestion) ───────────────────────────────────
# Runs at sync completion; writes row-level stats.leiden. Fixed defaults
# intentionally — active-set carousel Leiden is configurable separately.
# See spec §4.5.
PER_SYNC_LEIDEN_ENABLED=true
PER_SYNC_LEIDEN_RESOLUTION=1.0        # more, smaller communities as this rises
PER_SYNC_LEIDEN_BETA=0.01             # refinement randomness; 0 disables
PER_SYNC_LEIDEN_ITERATIONS=10         # more iterations = more stable, slower
PER_SYNC_LEIDEN_MIN_CLUSTER_SIZE=4    # below this → "Other" bucket
PER_SYNC_LEIDEN_SEED=42               # deterministic reproduction
PER_SYNC_LEIDEN_TIMEOUT_S=30          # skip Leiden if exceeded
FINALIZE_STATS_TIMEOUT_S=15           # guard for non-Leiden stats pass

# ── Active-set Leiden (graph) ────────────────────────────────────
# On-demand carousel computation. See spec §5.6.
ACTIVE_SET_LEIDEN_ENABLED=true
ACTIVE_SET_LEIDEN_TIMEOUT_S=15          # seconds before graspologic is cancelled
ACTIVE_SET_LEIDEN_LABELING_ENABLED=true # LLM-generated community labels via dense/lazy-lamacpp
ACTIVE_SET_LEIDEN_LABEL_MODEL=dense     # lazy-lamacpp systemd unit name
LEIDEN_CACHE_TTL_HOURS=24               # cache row lifetime before TTL sweep
LEIDEN_CACHE_SWEEP_INTERVAL_S=900       # 15 min — bounded delete (LIMIT 500)
LEIDEN_CACHE_MAX_ROWS_PER_USER=20       # LRU eviction cap
LEIDEN_COMMUNITY_SAMPLE_SIZE=20         # nodes returned per CommunityEntry in /api/communities; higher = larger payload, fewer drill-down round-trips
